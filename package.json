{
  "name": "corvus",
  "version": "0.4.0",
  "description": "Sync commits from multiple Git providers and serve a contribution calendar.",
  "author": "Patrik Elfström <me@patrikelfstrom.se>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patrikelfstrom/corvus.git"
  },
  "private": true,
  "license": "MIT",
  "type": "module",
  "bin": {
    "corvus": "./scripts/cli.ts"
  },
  "scripts": {
    "dev": "nitro dev",
    "build": "nitro build",
    "start": "bun .output/server/index.mjs",
    "corvus": "bun scripts/cli.ts",
    "prepare": "lefthook install",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "biome:ci": "bunx @biomejs/biome ci .",
    "check": "bunx @biomejs/biome check .",
    "check:fix": "bunx @biomejs/biome check --write .",
    "verify": "bun run test && bun run typecheck && bun run check && bun run build",
    "verify:fix": "bun run test && bun run typecheck && bun run check:fix && bun run build"
  },
  "dependencies": {
    "@observablehq/plot": "^0.6.17",
    "d3": "^7.9.0",
    "jsdom": "^28.1.0",
    "nitro": "3.0.1-alpha.2",
    "ofetch": "^2.0.0-alpha.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "std-env": "^4.0.0-rc.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/bun": "^1.3.9",
    "@types/d3": "^7.4.3",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^22.10.2",
    "lefthook": "1.12.3",
    "rolldown": "^1.0.0-rc.5",
    "typescript": "^5.7.2"
  },
  "packageManager": "bun@1.2.5",
  "engines": {
    "bun": ">=1.2.5",
    "node": ">=24"
  }
}
